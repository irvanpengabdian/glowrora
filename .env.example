# Neon (https://neon.tech) — used by the app (HTTP) and by drizzle-kit migrate (via devDependency `pg`, TCP)
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Clerk (https://dashboard.clerk.com) — enable Email + Magic link for admin
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk webhooks → `/api/webhooks/clerk` (user.created, user.updated, user.deleted)
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# Canonical production URL (optional; recommended on Vercel)
NEXT_PUBLIC_APP_URL="https://trustify.io"

# Abuse protection (Upstash Redis) — optional, recommended for production
# Create a DB at https://console.upstash.com/redis and use REST credentials.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sprint 4+ — Cloudflare R2 (S3-compatible API for presigned video uploads)
# Create API token with Object Read & Write on the bucket. Add a CORS rule on the bucket
# allowing PUT from your site origin (and localhost during dev).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional: public URL for playback (Wall / widget, Sprint 5)
# R2_PUBLIC_BASE_URL=
